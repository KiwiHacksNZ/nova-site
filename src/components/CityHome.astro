---
import { SIGNUP_URL, type City } from "../data/cities";

// This component now reads city from the state
const { city } = Astro.props;

const galleryImages = [
  "/images/DSCF3841.jpg",
  "/images/DSCF4012.jpg",
  "/images/DSCF2200.jpg",
  "/images/DSCF3768.jpg",
  "/images/DSCF3771.jpg",
  "/images/DSCF7194.jpg",
];
---

<div
  class="mx-auto flex max-w-5xl flex-col items-center px-5 pt-16 pb-24 text-center sm:pt-24"
>
  {/* 1. Big centered KiwiHacks presents... Nova logo */}
  <img
    src="/images/Kiwihacks_-_Nova_Logo_2.png"
    alt="KiwiHacks presents Nova"
    class="h-80 w-auto select-none sm:h-[28rem]"
  />

  {/* 2. City subtitle */}
  <p class="mt-8 max-w-2xl text-xl text-white sm:text-2xl">
    {city.name}&apos;s free 24-hour hackathon for high school students
  </p>

  {/* 3. Pink banner: city + date (Location/People still TBC) */}
  <div
    class="mt-7 w-full rounded-[2rem] bg-[#cf6da0] px-6 py-7 text-center shadow-lg"
  >
    <p
      class="text-lg font-semibold uppercase tracking-wide text-white sm:text-2xl"
    >
      {city.name}
      {"  ·  "}
      {city.date}
      {"  ·  "}Location TBC
    </p>
  </div>

  {/* 4. Sign up button */}
  <div class="mt-9">
    <a
      href={SIGNUP_URL}
      class="inline-block rounded-2xl bg-[#4f46e5] px-12 py-4 text-lg font-semibold text-white no-underline shadow-lg transition-colors hover:bg-[#5b52ee]"
    >
      Sign up for Nova!
    </a>
  </div>

  {/* 5. About Nova */}
  <section class="mt-24 w-full">
    <h2 class="text-center text-4xl font-semibold text-white sm:text-5xl">
      About Nova
    </h2>

    <div
      class="mx-auto mt-8 max-w-3xl space-y-5 text-left text-lg leading-relaxed text-white/85 sm:text-xl"
    >
      <p>
        KiwiHacks Nova is a constellation of three hackathons across New
        Zealand. Three cities, three weekends, three free 24-hour hackathons for
        high schoolers. A nova is a star that suddenly bursts bright, and
        that&apos;s the idea: light up Wellington, Christchurch, and Auckland
        with students building real things.
      </p>
      <p>
        Nova is a chance to meet new people, learn new skills, and build
        something you&apos;re actually proud of, whether that&apos;s an app, a
        game, a website, a hardware project, or something nobody has seen
        before! You team up, you get 24 hours, and you ship. Mentors will be
        around for the entire event, and beginner-friendly workshops mean you
        don't need any prior experience to get started. Food, drinks, and swag
        are all included, and everything is completely free!
      </p>
      <p>
        We're KiwiHacks, New Zealand&apos;s first high school hackathon club,
        built and run entirely by teenagers! At KiwiHacks &rsquo;26 earlier this
        year, over 100 high schoolers turned up and every team left with a
        shipped project they were proud of. Plus, all of them made a new friend.
        Nova takes that across the country. Whatever your skill level, you are
        welcome. Just sign up, show up, and give it a go.
      </p>
    </div>

    <div class="relative mt-12" data-carousel>
      <div
        data-carousel-track
        class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth rounded-2xl shadow-lg ring-1 ring-white/10"
      >
        {
          galleryImages.map((src, index) => (
            <div class="aspect-[16/9] w-full shrink-0 snap-center overflow-hidden">
              <img
                src={src}
                alt="KiwiHacks event photo"
                loading="lazy"
                class={`h-full w-full object-cover ${index === galleryImages.length - 1 ? "origin-left scale-110 object-left" : ""}`}
              />
            </div>
          ))
        }
      </div>

      {/* Prev / Next arrows */}
      <button
        type="button"
        data-carousel-prev
        aria-label="Previous photo"
        class="absolute top-1/2 left-3 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur transition-colors hover:bg-black/60"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path
            d="M15 6l-6 6 6 6"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Next photo"
        class="absolute top-1/2 right-3 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur transition-colors hover:bg-black/60"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path
            d="M9 6l6 6-6 6"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      {/* Dot indicators */}
      <div class="mt-4 flex items-center justify-center gap-2">
        {
          galleryImages.map((_, index) => (
            <button
              type="button"
              data-carousel-dot={index}
              aria-label={`Go to photo ${index + 1}`}
              class="h-2.5 w-2.5 rounded-full bg-white/30 transition-colors data-[active=true]:bg-white"
            />
          ))
        }
      </div>
    </div>
  </section>

  {
    /* Partners section hidden for now. Re-enable once we have partners to show. */
  }
</div>

<script>
  // Photo carousel: scroll-snap track driven by arrow buttons, dots,
  // and a paused-on-interaction autoplay loop.
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-carousel-track]");
    const prev = root.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-carousel-next]");
    const dots = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]"),
    );
    if (!track) return;

    const slideCount = track.children.length;
    let activeIndex = 0;
    let autoplay: ReturnType<typeof setInterval> | undefined;

    function setActive(index: number) {
      activeIndex = (index + slideCount) % slideCount;
      dots.forEach((dot, i) =>
        dot.toggleAttribute("data-active", i === activeIndex),
      );
    }

    function goTo(index: number, smooth = true) {
      setActive(index);
      const slide = track?.children[activeIndex] as HTMLElement | undefined;
      if (slide) {
        track?.scrollTo({
          left: slide.offsetLeft,
          behavior: smooth ? "smooth" : "auto",
        });
      }
    }

    function startAutoplay() {
      stopAutoplay();
      autoplay = setInterval(() => goTo(activeIndex + 1), 6000);
    }

    function stopAutoplay() {
      if (autoplay) clearInterval(autoplay);
    }

    prev?.addEventListener("click", () => {
      goTo(activeIndex - 1);
      startAutoplay();
    });

    next?.addEventListener("click", () => {
      goTo(activeIndex + 1);
      startAutoplay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        startAutoplay();
      });
    });

    // Keep dots in sync when the user swipes/scrolls the track directly.
    track.addEventListener("scroll", () => {
      const index = Math.round(track.scrollLeft / track.clientWidth);
      setActive(index);
    });

    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);

    setActive(0);
    startAutoplay();
  });
</script>
