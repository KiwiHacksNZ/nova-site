---
import NovaLogo from "./NovaLogo.astro";
import { SIGNUP_URL, type City } from "../data/cities";

// Home page content, driven by the city in the URL ("/" defaults to Auckland).
interface Props {
  city: City;
}

const { city } = Astro.props;

const galleryImages = [
  "/images/DSCF3841.jpg",
  "/images/DSCF4012.jpg",
  "/images/DSCF2200.jpg",
  "/images/DSCF3768.jpg",
  "/images/DSCF3771.jpg",
  "/images/DSCF7194.jpg",
];

const carouselImages = [
  galleryImages[galleryImages.length - 1],
  ...galleryImages,
  galleryImages[0],
];
---

<div
  class="mx-auto flex max-w-5xl flex-col items-center px-5 pt-16 pb-24 text-center sm:pt-24"
>
  {/* 1. Big centered Nova logo + By KiwiHacks (links to kiwihacks.org) */}
  <div class="flex flex-col items-center">
    <NovaLogo class="h-40 sm:h-60" />
    <a
      href="https://kiwihacks.org"
      class="-mt-9 self-end text-xl text-white/90 no-underline transition-colors hover:text-white sm:-mt-14 sm:mr-6"
    >
      By KiwiHacks
    </a>
  </div>

  {/* 2. City subtitle */}
  <p class="mt-8 max-w-2xl text-xl text-white sm:text-2xl">
    {city.name}&apos;s free 24-hour hackathon for high school students
  </p>

  {/* 3. Pink banner: city + date (Location/People still TBC) */}
  <div
    class="mt-7 w-full rounded-[2rem] bg-[#cf6da0] px-6 py-7 text-center shadow-lg"
  >
    <p
      class="text-lg font-semibold uppercase tracking-wide text-white sm:text-2xl"
    >
      {city.name}
      {"  ·  "}
      {city.date}
      {"  ·  "}Location TBC
    </p>
  </div>

  {/* 4. Sign up button */}
  <div class="mt-9">
    <a
      href={SIGNUP_URL}
      class="inline-block rounded-2xl bg-[#4f46e5] px-12 py-4 text-lg font-semibold text-white no-underline shadow-lg transition-colors hover:bg-[#5b52ee]"
    >
      Sign up for Nova!
    </a>
  </div>

  {/* 5. About Nova */}
  <section class="mt-24 w-full">
    <h2 class="text-center text-4xl font-semibold text-white sm:text-5xl">
      About Nova
    </h2>

    <div
      class="mx-auto mt-8 max-w-3xl space-y-5 text-left text-lg leading-relaxed text-white/85 sm:text-xl"
    >
      <p>
        KiwiHacks Nova is a constellation of three hackathons across New
        Zealand. Three cities, three weekends, three free 24-hour hackathons for
        high schoolers. A nova is a star that suddenly bursts bright, and
        that&apos;s the idea: light up Wellington, Christchurch, and Auckland
        with students building real things.
      </p>
      <p>
        Nova is a chance to meet new people, learn new skills, and build
        something you&apos;re actually proud of, whether that&apos;s an app, a
        game, a website, a hardware project, or something nobody has seen
        before! You team up, you get 24 hours, and you ship. Mentors will be
        around for the entire event, and beginner-friendly workshops mean you
        don't need any prior experience to get started. Food, drinks, and swag
        are all included, and everything is completely free!
      </p>
      <p>
        We're KiwiHacks, New Zealand&apos;s first high school hackathon club,
        built and run entirely by teenagers! At KiwiHacks &rsquo;26 earlier this
        year, over 100 high schoolers turned up and every team left with a
        shipped project they were proud of. Plus, all of them made a new friend.
        Nova takes that across the country. Whatever your skill level, you are
        welcome. Just sign up, show up, and give it a go.
      </p>
    </div>

    <div class="relative mt-12">
      <button
        type="button"
        data-gallery-prev
        class="absolute left-3 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-xl bg-[#4f46e5]/90 text-white shadow-lg ring-1 ring-white/15 transition-colors hover:bg-[#5b52ee] sm:inline-flex"
        aria-label="Previous photo"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path
            d="M15 19l-7-7 7-7"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      <div
        data-gallery-carousel
        class="-mx-5 flex snap-x gap-4 overflow-x-auto scroll-smooth px-5 pb-4 sm:mx-0 sm:px-0 sm:pb-0"
      >
        {
          carouselImages.map((src) => (
            <div
              data-gallery-slide
              class="aspect-[4/3] w-[82vw] shrink-0 snap-center overflow-hidden rounded-2xl shadow-lg ring-1 ring-white/10 sm:w-[72%] lg:w-[64%]"
            >
              <img
                src={src}
                alt="KiwiHacks event photo"
                loading="lazy"
                class={`h-full w-full object-cover ${src === galleryImages[galleryImages.length - 1] ? "origin-left scale-110 object-left" : ""}`}
              />
            </div>
          ))
        }
      </div>

      <button
        type="button"
        data-gallery-next
        class="absolute right-3 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-xl bg-[#4f46e5]/90 text-white shadow-lg ring-1 ring-white/15 transition-colors hover:bg-[#5b52ee] sm:inline-flex"
        aria-label="Next photo"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path
            d="M9 5l7 7-7 7"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </section>

  {
    /* Partners section hidden for now. Re-enable once we have partners to show. */
  }
</div>

<script>
  const galleryCarousel = document.querySelector<HTMLElement>(
    "[data-gallery-carousel]",
  );
  const galleryPrev = document.querySelector<HTMLButtonElement>(
    "[data-gallery-prev]",
  );
  const galleryNext = document.querySelector<HTMLButtonElement>(
    "[data-gallery-next]",
  );
  let galleryIndex = 1;
  let resetTimer: number | undefined;

  function gallerySlides() {
    return Array.from(
      galleryCarousel?.querySelectorAll<HTMLElement>("[data-gallery-slide]") ??
        [],
    );
  }

  function syncGalleryIndex() {
    if (!galleryCarousel) return;

    const slides = gallerySlides();
    const closest = slides.reduce(
      (best, slide, index) => {
        const distance = Math.abs(
          slide.offsetLeft - galleryCarousel.scrollLeft,
        );
        return distance < best.distance ? { index, distance } : best;
      },
      { index: galleryIndex, distance: Number.POSITIVE_INFINITY },
    );

    galleryIndex = closest.index;
  }

  function scrollToGalleryIndex(index: number, behavior: ScrollBehavior) {
    if (!galleryCarousel) return;

    const slides = gallerySlides();
    const slide = slides[index];
    if (!slide) return;

    galleryIndex = index;
    galleryCarousel.scrollTo({ left: slide.offsetLeft, behavior });
  }

  function resetInfiniteEdge() {
    const slides = gallerySlides();
    if (galleryIndex === 0) {
      scrollToGalleryIndex(slides.length - 2, "auto");
      return;
    }

    if (galleryIndex === slides.length - 1) {
      scrollToGalleryIndex(1, "auto");
    }
  }

  function scheduleInfiniteReset() {
    if (!galleryCarousel) return;

    window.clearTimeout(resetTimer);

    let resetComplete = false;
    const reset = () => {
      if (resetComplete) return;
      resetComplete = true;
      resetInfiniteEdge();
      galleryCarousel.removeEventListener("scrollend", reset);
    };

    galleryCarousel.addEventListener("scrollend", reset, { once: true });
    resetTimer = window.setTimeout(reset, 450);
  }

  function scrollGallery(direction: -1 | 1) {
    const slides = gallerySlides();
    if (!galleryCarousel || slides.length === 0) return;

    syncGalleryIndex();

    const nextIndex = Math.max(
      0,
      Math.min(slides.length - 1, galleryIndex + direction),
    );

    scrollToGalleryIndex(nextIndex, "smooth");

    if (nextIndex === 0 || nextIndex === slides.length - 1) {
      scheduleInfiniteReset();
    }
  }

  requestAnimationFrame(() => scrollToGalleryIndex(1, "auto"));

  galleryPrev?.addEventListener("click", () => scrollGallery(-1));
  galleryNext?.addEventListener("click", () => scrollGallery(1));
</script>
