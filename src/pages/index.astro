---
import Layout from "../layouts/Layout.astro";
import CityHome from "../components/CityHome.astro";
import { DEFAULT_CITY } from "../data/cities";

// Root "/" defaults to Auckland. Other cities live at "/wellington", "/christchurch", "/auckland".
---

<Layout>
  <CityHome city={DEFAULT_CITY} />
</Layout>

<script>
  // If a city is saved in localStorage, redirect to that city's page
  const savedCity = localStorage.getItem("selectedCity");
  if (savedCity) {
    window.location.href = `/${savedCity}`;
  }
</script>
