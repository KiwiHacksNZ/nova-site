---
import Layout from "../layouts/Layout.astro";
import NovaLogo from "../components/NovaLogo.astro";
type Faq = { q: string; a: string };

const FAQ_ITEMS: Faq[] = [
  {
    q: "Who can attend KiwiHacks Nova Enterprise?",
    a: "Founders, builders, students, mentors, enterprise stakeholders, procurement teams, auditors, and anyone who wants a hackathon-like path into AI B2B SaaS agentic machine-learning data-lake transformation.",
  },
  {
    q: "Do I need prior quantum, blockchain, or Mamba-2.5 experience?",
    a: "No. Beginner-friendly workshops still exist. You can arrive with no code, no model registry, and no zero-knowledge proof strategy, then leave with a pitch deck, prototype, and several responsible-AI acronyms.",
  },
  {
    q: "What should I bring to the activation?",
    a: "Bring a laptop, charger, water bottle, any devices you want to integrate, and a sleeping bag if you want to rest. Optional extras include a threat model, carbon budget, haptic feedback rig, and dogecoin wallet.",
  },
  {
    q: "Is the synergy layer free?",
    a: "Yes, the event remains free to attend. Food, mentors, workshops, swag, vibes, and provisional enterprise resonance are covered by sponsors. Cost is never a barrier at KiwiHacks.",
  },
  {
    q: "What can I build?",
    a: "Anything you can build in 24 hours: an app, game, website, hardware prototype, graph-RAG demo, blockchain-backed consensus layer, sustainability dashboard, multimodal search tool, or consciousness-upload endpoint mock.",
  },
  {
    q: "Is this actually compliant?",
    a: "The website is compliant with the joke. The event still has real supervision, clear expectations, guardian communication where relevant, and a code of conduct. Any SOC2, FedRAMP, or ISO claims should be read as aspirational theater.",
  },
  {
    q: "How about safety and zero trust?",
    a: "The venue is supervised around the clock with check-in and check-out, first aid on site, a clear code of conduct, and guardian contact details collected where needed. The zero-trust part mostly means we do not trust the buzzword roadmap either.",
  },
  {
    q: "What if I have more questions?",
    a: "Email niko@kiwihacks.org or join the KiwiHackers Discord at kiwihacks.org/discord. We reply fast, unless the ambient mesh is busy negotiating with the semantic cache.",
  },
];
---

<Layout title="Due Diligence | KiwiHacks Nova Enterprise">
  <div class="mx-auto max-w-5xl px-5 pt-6 pb-24">
    {/* Back button */}
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-xl bg-[#4f46e5] px-4 py-2 text-sm font-medium text-white no-underline transition-colors hover:bg-[#5b52ee]"
    >
      <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
        <path
          d="M15 19l-7-7 7-7"
          stroke="white"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      Back
    </a>

    {/* Logo + FAQ heading */}
    <div
      class="mt-8 flex flex-wrap items-center justify-center gap-6 sm:justify-start"
    >
      <div class="flex flex-col items-center">
        <NovaLogo class="h-20 sm:h-28" />
      </div>
      <h1 class="text-5xl font-semibold text-white sm:text-7xl">
        Due Diligence
      </h1>
    </div>

    {/* 2-column card grid (stacks on mobile) */}
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        FAQ_ITEMS.map((item) => (
          <div class="rounded-xl bg-[#5c2a42]/85 p-6 ring-1 ring-white/5">
            <h3 class="text-lg font-semibold text-[#db74a8]">{item.q}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/80">{item.a}</p>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
