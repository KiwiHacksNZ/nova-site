---
import "../styles/global.css";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "KiwiHacks Nova",
  description = "Nova: New Zealand's free 24-hour hackathon for high school students, by KiwiHacks.",
  ogImage = "/nova-logo.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://nova.kiwihacks.org");
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0d28" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/nova-logo.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL)} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonicalURL)} />
    <!-- Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "KiwiHacks",
      "url": "https://nova.kiwihacks.org",
      "description": "New Zealand's first high school hackathon club, built and run entirely by teenagers.",
      "sameAs": ["https://kiwihacks.org"]
    })} />
    <script>
      // Restore city selector label from localStorage immediately to prevent flash
      const savedCity = localStorage.getItem("selectedCity");
      if (savedCity) {
        const cityNames = {
          wellington: "Wellington",
          christchurch: "Christchurch",
          auckland: "Auckland",
        };
        const cityName = cityNames[savedCity];
        if (cityName) {
          const observer = new MutationObserver(() => {
            const toggle = document.querySelector("[data-city-toggle]");
            if (toggle) {
              const span = toggle.querySelector("span");
              if (span && span.textContent !== cityName) {
                span.textContent = cityName;
              }
              observer.disconnect();
            }
          });
          observer.observe(document.documentElement, {
            childList: true,
            subtree: true,
          });
        }
      }
    </script>
  </head>
  <body class="flex min-h-full flex-col">
    <NavBar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
